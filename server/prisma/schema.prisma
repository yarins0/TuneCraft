// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Prisma schema defines the database connection and all table structures
// Prisma uses this file to generate the database tables and the TypeScript client

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // pooled connection — used at runtime
  directUrl = env("DIRECT_DATABASE_URL") // direct connection — used by prisma migrate
}

// Identifies which streaming service a row belongs to.
// All existing rows default to SPOTIFY — new platforms are added here when adapters are built.
enum Platform {
  SPOTIFY
  SOUNDCLOUD
  TIDAL
  APPLE_MUSIC
}

model User {
  id             String     @id @default(cuid())  // unique internal ID
  platformUserId String                           // the platform's own user ID (e.g. Spotify "id" field)
  displayName    String
  email          String?                          // optional, not all Spotify accounts have email
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  platform       Platform   @default(SPOTIFY)     // which streaming service this user authenticated with
  createdAt      DateTime   @default(now())

  // One user can have many playlists
  playlists      Playlist[]

  // platformUserId alone is not globally unique — Spotify and SoundCloud have separate
  // ID namespaces that could collide. The combination of (platformUserId, platform) is unique.
  @@unique([platformUserId, platform])
}

model Playlist {
  id                String    @id @default(cuid())
  platformPlaylistId String                         // not unique — multiple users can track same playlist
  name              String
  autoReshuffle     Boolean   @default(false)
  intervalDays      Int?                           // every N days (null = not set)
  algorithms        Json?                          // which shuffle algorithms to apply
  lastReshuffledAt  DateTime?
  nextReshuffleAt   DateTime?                      // pre-computed, used by cron job to find due playlists
  platform          Platform  @default(SPOTIFY)    // which platform this playlist lives on

  createdAt         DateTime  @default(now())

  // Every playlist belongs to one user
  userId            String
  user              User      @relation(fields: [userId], references: [id])

  // Prevent duplicate entries — one user can only track one auto-reshuffle per playlist
  @@unique([userId, platformPlaylistId])
}

model TrackCache {
  id            String   @id @default(cuid())

  // One column per platform — keyed by ISRC when available so the same recording
  // is never fetched from ReccoBeats twice, no matter which platform surfaces it.
  // All three are optional because a row may be created before all IDs are resolved.
  isrc          String?  @unique   // International Standard Recording Code (cross-platform)
  spotifyId     String?  @unique   // Spotify track ID
  soundcloudId  String?  @unique   // SoundCloud track ID (numeric, stored as string)
  tidalId       String?  @unique   // Tidal track ID (numeric, stored as string)
  // Add more platform ID columns here as new adapters are built (e.g. appleMusicId)

  audioFeatures Json
  cachedAt      DateTime @default(now())
}

model ArtistCache {
  id         String   @id @default(cuid())
  artistId   String   @unique               // artist ID on the platform
  artistName String
  genres     Json
  platform   Platform @default(SPOTIFY)     // platform that issued this artist ID
  cachedAt   DateTime @default(now())
}