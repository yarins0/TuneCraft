# ── URLs ─────────────────────────────────────────────────────────────────────────
# SERVER_URL  — the backend (Railway / wherever the server runs)
#               OAuth redirect URIs are derived from this automatically.
#               Dev:  http://127.0.0.1:3000
#               Prod: https://your-api-domain.up.railway.app
#
# FRONTEND_URL — the frontend (Vercel / wherever the client is hosted)
#                After OAuth login the server redirects the browser here.
#                Dev:  http://127.0.0.1:5173
#                Prod: https://your-app.vercel.app
SERVER_URL=http://127.0.0.1:3000
FRONTEND_URL=http://127.0.0.1:5173

# ── Spotify OAuth ──────────────────────────────────────────────────────────────
# Create app at https://developer.spotify.com/dashboard
# Register redirect URI: {SERVER_URL}/auth/spotify/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── SoundCloud OAuth ────────────────────────────────────────────────────────────
# Create app at https://soundcloud.com/you/apps
# Register redirect URI: {SERVER_URL}/auth/soundcloud/callback
SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id_here
SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret_here

# ── Tidal OAuth ─────────────────────────────────────────────────────────────────
# Create app at https://developer.tidal.com/dashboard
# Register redirect URI: {SERVER_URL}/auth/tidal/callback
TIDAL_CLIENT_ID=your_tidal_client_id_here
TIDAL_CLIENT_SECRET=your_tidal_client_secret_here

# ── YouTube / YouTube Music OAuth ───────────────────────────────────────────────
# Create a project at https://console.cloud.google.com
# Enable the YouTube Data API v3 under "APIs & Services > Library"
# Create OAuth 2.0 credentials (Web application type) under "APIs & Services > Credentials"
# Register redirect URI: {SERVER_URL}/auth/youtube/callback
# Add test users under "OAuth consent screen > Test users" while the app is in development
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here

# ── Last.fm ─────────────────────────────────────────────────────────────────────
# Create app at https://www.last.fm/api/account/create
LASTFM_API_KEY=your_lastfm_api_key_here
LASTFM_SECRET=your_lastfm_secret_here

# ── Database ────────────────────────────────────────────────────────────────────
# DATABASE_URL      — pooled connection, used at runtime by the app
# DIRECT_DATABASE_URL — direct (non-pooled) connection, required by prisma migrate dev
# Format: postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# ── Resend (email) ───────────────────────────────────────────────────────────────
# Create account + API key at https://resend.com
# ADMIN_EMAIL is where Spotify access request notifications will be sent
RESEND_API_KEY=your_resend_api_key_here
ADMIN_EMAIL=your_email_here

# ── Server port ─────────────────────────────────────────────────────────────────
PORT=3000

# ── Auth token signing ───────────────────────────────────────────
# Random secret used to sign user tokens (HMAC-SHA256). Any string works --
# generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this invalidates all existing sessions (all users must re-login).
HMAC_SECRET=your_hmac_secret_here
